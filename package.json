{
  "name": "jeraya-app-starter",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build:app": "vite build -c vite.app.config.ts",
    "build:functions": "tsx scripts/build.functions.ts",
    "build:automations": "vite build -c vite.automations.config.ts",
    "build": "npm run build:app && npm run build:functions && npm run build:automations",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@jeraya/sdk": "file:../../projects/jeraya/packages/jeraya-sdk",
    "@tailwindcss/vite": "^4.3.0",
    "daisyui": "^5.5.23",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "firebase": "^12.14.0",
    "nocodb-sdk": "^0.301.3",
    "open": "^11.0.0",
    "preact": "^10.29.1",
    "preact-router": "^4.1.2",
    "tailwindcss": "^4.3.0",
    "wouter-preact": "^3.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^8.0.12",
    "vitest": "^3.1.1"
  }
}
